# WhatsApp CRM for SA SMMEs — Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# ─── Getting started with OpenWA (recommended) ─────────────────────
# 1. Start OpenWA:
#      docker run -p 2785:2785 -p 2886:2886 --name openwa rmyndharis/openwa:0.1.4
# 2. Open http://localhost:2886 → create a session → scan QR with your phone
# 3. Copy the API key & session ID here
# 4. Set WHATSAPP_PROVIDER=openwa below
#
# Full OpenWA docs: https://github.com/rmyndharis/OpenWA

# ─── App ──────────────────────────────────────────────────────
APP_NAME=WhatsApp CRM SA
APP_URL=https://your-domain.com
ENVIRONMENT=development        # development | staging | production
DEBUG=true
SECRET_KEY=change-this-to-a-random-string-min-32-chars
SA_TIMEZONE=Africa/Johannesburg

# ─────────────────────────────────────────────────────────────
# WHATSAPP PROVIDER  ← pick ONE
# ─────────────────────────────────────────────────────────────
# openwa  = self-hosted WhatsApp gateway  ← FREE, RECOMMENDED
# meta    = Meta Business API             ← requires Meta approval
# twilio  = Twilio WhatsApp API           ← pay-per-message
WHATSAPP_PROVIDER=openwa

# ─── OpenWA (rmyndharis/OpenWA v0.1.4) ──────────────────────
# URL of your running OpenWA instance (default on localhost)
OPENWA_API_URL=http://localhost:2785

# API key generated from OpenWA dashboard → Settings → API Access
# Used for every CRM → OpenWA REST call
OPENWA_API_KEY=ow_live_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# The OpenWA session name (created in the OpenWA dashboard)
# Example: default
OPENWA_SESSION_ID=default

# Optional: HMAC key for OpenWA audit log verification
# Configure this in OpenWA → Settings → Webhook HMAC
OPENWA_HMAC_KEY=

# Optional: webhook secret — used to verify OpenWA events
# OpenWA sends events to: POST http://your-crm/api/webhooks/openwa
OPENWA_WEBHOOK_SECRET=

# ─── Meta Business API ────────────────────────────────────────
META_PHONE_NUMBER_ID=your-phone-number-id
META_ACCESS_TOKEN=your-permanent-access-token
META_BUSINESS_ACCOUNT_ID=your-business-account-id

# ─── Twilio WhatsApp ─────────────────────────────────────────
TWILIO_ACCOUNT_SID=your-account-sid
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ─── AI Backend (free tier — at least one required) ───────────
# Groq: https://console.groq.com  (free, no CC, 14,400 req/day)
GROQ_API_KEY=gsk_your-key-here

# OpenRouter: https://openrouter.ai  (free tier available)
OPENROUTER_API_KEY=sk-or-your-key-here

AI_PROVIDER=auto   # groq | openrouter | auto (try groq first)

# ─── SMS Fallback (Africa's Talking) ─────────────────────────
AFRICASTALKING_API_KEY=your-at-api-key
AFRICASTALKING_USERNAME=your-username
SMS_SENDER_ID=YourBrandName

# ─── Email ───────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASSWORD=your-app-password
NOTIFICATION_EMAIL=admin@yourbusiness.co.za

# ─── Payments (SA ZAR) ──────────────────────────────────────
PAYFAST_MERCHANT_ID=your-merchant-id
PAYFAST_MERCHANT_KEY=your-merchant-key
PAYFAST_PASSPHRASE=your-passphrase

# ─── Media Storage ──────────────────────────────────────────
SUPABASE_STORAGE_URL=https://your-project.supabase.co/storage/v1
SUPABASE_SERVICE_KEY=your-service-key

# ─── DB ─────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[REF].supabase.co:5432/postgres

# ─── Rate limits ────────────────────────────────────────────
MAX_CONVERSATIONS_PER_DAY=200
MAX_MESSAGES_PER_CONVERSATION=50
AI_RATE_LIMIT_PER_MINUTE=18
BUSINESS_HOURS_START=8
BUSINESS_HOURS_END=18
AUTO_REPLY_ENABLED=true
MESSAGE_DELAY_MIN=1
AUTO_REPLY_TYPING_DELAY=2
