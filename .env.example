# WhatsApp CRM for SA SMMEs — Environment Variables
# Copy to .env and fill in values
#
# cp .env.example .env

# ─── App ──────────────────────────────────────────────────────
APP_NAME=WhatsApp CRM SA
APP_URL=https://your-domain.com
ENVIRONMENT=development  # development | staging | production
DEBUG=true
SECRET_KEY=change-this-to-a-random-string-minimum-32-chars
SA_TIMEZONE=Africa/Johannesburg

# ─── Database (Supabase PostgreSQL) ──────────────────────────
# Free at: https://supabase.com (500MB, 50K rows free)
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[REF].supabase.co:5432/postgres

# ─── WhatsApp Business API ───────────────────────────────────
# Option 1: Meta Business API (direct — free, requires approval)
#   https://developers.facebook.com/docs/whatsapp/cloud-api
META_PHONE_NUMBER_ID=your-phone-number-id
META_ACCESS_TOKEN=your-permanent-access-token
META_BUSINESS_ACCOUNT_ID=your-business-account-id

# Option 2: Twilio WhatsApp (easier setup, pay-per-message)
TWILIO_ACCOUNT_SID=your-account-sid
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886  # Twilio sandbox or registered number

# Choose provider: meta | twilio
WHATSAPP_PROVIDER=meta

# ─── AI Backend (Free — at least one required) ────────────────
# Groq: https://console.groq.com (free, no credit card, 14400 req/day)
GROQ_API_KEY=gsk_your-key-here

# OpenRouter: https://openrouter.ai (free, no credit card, 50 req/day)
OPENROUTER_API_KEY=sk-or-your-key-here

# Primary AI provider: groq | openrouter | auto (tries Groq first)
AI_PROVIDER=auto

# ─── SMS Fallback (for non-WhatsApp users) ────────────────────
# Africa's Talking: https://www.africastalking.com
AFRICASTALKING_API_KEY=your-api-key
AFRICASTALKING_USERNAME=your-username
SMS_SENDER_ID=YourBrand

# ─── Email (for admin notifications) ──────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASSWORD=your-app-password
NOTIFICATION_EMAIL=admin@yourbusiness.co.za

# ─── Payments (SA ZAR) ───────────────────────────────────────
# PayFast: https://www.payfast.co.za (SA payment gateway)
PAYFAST_MERCHANT_ID=your-merchant-id
PAYFAST_MERCHANT_KEY=your-merchant-key
PAYFAST_PASSPHRASE=your-passphrase

# ─── Media Storage ───────────────────────────────────────────
# Supabase Storage or S3-compatible
SUPABASE_STORAGE_URL=https://your-project.supabase.co/storage/v1
SUPABASE_SERVICE_KEY=your-service-key

# ─── Rate Limits ──────────────────────────────────────────────
MAX_CONVERSATIONS_PER_DAY=200
MAX_MESSAGES_PER_CONVERSATION=50
AI_RATE_LIMIT_PER_MINUTE=18
BUSINESS_HOURS_START=8    # 8 AM SAST
BUSINESS_HOURS_END=18     # 6 PM SAST
AUTO_REPLY_ENABLED=true
MESSAGE_DELAY_MIN=1       # Delay between AI replies (human-like)
AUTO_REPLY_TYPING_DELAY=2 # Simulated typing indicator delay