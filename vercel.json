{
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    { "src": "/health", "dest": "/api/index.py" },
    { "src": "/auth/(.*)", "dest": "/api/index.py" },
    { "src": "/api/auth/(.*)", "dest": "/api/index.py" },
    { "src": "/api/admin/(.*)", "dest": "/api/index.py" },
    { "src": "/api/contacts/(.*)", "dest": "/api/index.py" },
    { "src": "/api/conversations/(.*)", "dest": "/api/index.py" },
    { "src": "/api/messages/(.*)", "dest": "/api/index.py" },
    { "src": "/api/campaigns/(.*)", "dest": "/api/index.py" },
    { "src": "/api/ai/(.*)", "dest": "/api/index.py" },
    { "src": "/api/dashboard/(.*)", "dest": "/api/index.py" },
    { "src": "/api/webhooks/(.*)", "dest": "/api/index.py" },
    { "src": "/setup", "dest": "/api/index.py" },
    { "src": "/(.*)", "dest": "/api/index.py" }
  ]
}