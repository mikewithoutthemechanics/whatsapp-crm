{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "Dockerfile",
    "buildCommand": ""
  },
  "deploy": {
    "startCommand": "uvicorn app.main:app --host 0.0.0.0 --port 8000 --log-level info",
    "healthcheckPath": "/health",
    "healthcheckTimeout": 10,
    "restartPolicyType": "on_failure",
    "restartPolicyMaxRetries": 10,
    "numReplicas": 1,
    "resources": {
      "cpu": "0.5",
      "memoryMiB": 512,
      "memoryMaxMiB": 1024
    }
  }
}
